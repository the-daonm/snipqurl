all:
  children:
    master:
      hosts:
        master_node:
          ansible_host: YOUR_MASTER_IP
          ansible_user: YOUR_USER
          ansible_ssh_private_key_file: ~/.ssh/id_ed25519
    worker:
      hosts:
        worker_node:
          ansible_host: YOUR_WORKER_IP
          ansible_user: YOUR_USER
          ansible_ssh_private_key_file: ~/.ssh/id_ed25519
          ansible_ssh_common_args: '-o ProxyCommand="ssh -W %h:%p -q USER@MASTER_IP"'
